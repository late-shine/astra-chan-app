# Firebase — client-side (VITE_ prefix exposes these to the browser, which is fine for Firebase)
VITE_FIREBASE_API_KEY=your-firebase-api-key-here
VITE_FIREBASE_DATABASE_URL=your-firebase-database-url-here

# Cloudflare Workers AI — server-side only (never exposed to browser)
# Get these from: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id-here
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token-here